# Keasy Environment Variables
# Copy this file to .env and fill in your values

# ─── Required ────────────────────────────────────────────────────────
# API key for server authentication (required)
KEASY_API_KEY=change-me

# Session cookie signing key (required — generate with: openssl rand -base64 32)
KEASY_SESSION_SECRET=change-me-in-production

# Encryption key for stored secrets (generate with: openssl rand -base64 32)
# If omitted, secrets are stored unencrypted.
KEASY_SECRET_KEY=change-me-in-production

# ─── Server ──────────────────────────────────────────────────────────
# Address to bind the HTTP server (default: 0.0.0.0:8080)
# KEASY_BIND_ADDR=0.0.0.0:8080

# Public base URL of this Keasy instance (used for OIDC redirect URIs, etc.)
# KEASY_BASE_URL=http://localhost:3000

# Path to the data directory (default: ./data)
# KEASY_DATA_DIR=./data

# CORS origins (comma-separated). Omit to allow all (a warning is logged).
# KEASY_CORS_ORIGINS=http://localhost:3000

# Set Secure flag on session cookies (requires HTTPS). Default: false.
# KEASY_SESSION_SECURE=true

# Max concurrent harvesting jobs (default: 4)
# KEASY_MAX_CONCURRENT_JOBS=4

# Per-job timeout in seconds (default: 600)
# KEASY_JOB_TIMEOUT_SECS=600

# Graceful shutdown timeout in seconds (default: 30)
# KEASY_SHUTDOWN_GRACE_SECS=30

# Output cache capacity (default: 64)
# KEASY_CACHE_CAPACITY=64

# Path to an external SQL seed file executed at startup (default: none)
# KEASY_SEED_FILE=infra/seeds/dev-promotor.sql

# ─── Keycloak / OIDC ────────────────────────────────────────────────
# All three are required to enable OIDC authentication and Keycloak admin.
# KEASY_OIDC_ISSUER_URL=http://keycloak:8080/auth/realms/keasy
# KEASY_OIDC_CLIENT_ID=keasy-server
# KEASY_OIDC_CLIENT_SECRET=keasy-dev-secret

# Optional: internal base URL for Keycloak if different from the public issuer
# (e.g. Docker internal network). Used for token introspection.
# KEASY_OIDC_INTERNAL_BASE_URL=http://keycloak:8080

# Keycloak admin password (used by docker-compose for initial setup)
# KC_ADMIN_PASSWORD=changeme

# Keycloak database password (used by docker-compose)
# KC_DB_PASSWORD=changeme

# ─── GXDCH (Gaia-X Compliance) ──────────────────────────────────────
# GXDCH Notary endpoint for LRN credential requests.
# Defaults to the Gaia-X staging Notary if omitted.
# KEASY_GXDCH_NOTARY_URL=https://registrationnumber.notary.gaia-x.eu/v1-staging

# GXDCH Compliance Service endpoint for VP submission.
# Defaults to the Gaia-X main/stable Compliance Service if omitted.
# KEASY_GXDCH_COMPLIANCE_URL=https://compliance.gaia-x.eu/v2206/api

# ─── Caddy TLS Certificates ──────────────────────────────────────────
# Path to Caddy's data directory for auto-reading TLS certificate chains.
# In production docker-compose this is mounted as /caddy-data.
# KEASY_CADDY_CERTS_DIR=/caddy-data
