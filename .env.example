# Keasy Environment Variables
# Copy this file to .env and fill in your values

# Keasy server secret key (generate with: openssl rand -base64 32)
KEASY_SECRET_KEY=change-me-in-production

# Keycloak Identity Service (activate with: docker compose --profile keycloak up)
KC_DB_PASSWORD=changeme
KC_ADMIN_PASSWORD=changeme
KEASY_OIDC_CLIENT_SECRET=keasy-dev-secret
