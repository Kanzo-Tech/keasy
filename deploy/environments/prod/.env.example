# Copy to `.env` (gitignored) on the Swarm manager and fill in. Read by
# infra/stack/bootstrap.sh (`make deploy-base`). Secret VALUES live here only to
# seed Swarm secrets on first bootstrap — they are not committed.

# ── Required ────────────────────────────────────────────────────────────────
KC_HOSTNAME=auth.keasy.example.com          # Keycloak's public host
KEASY_BASE_DOMAIN=keasy.example.com         # tenants at <slug>.<this>
ACME_EMAIL=ops@kanzo.tech                   # Let's Encrypt registration
KEASY_DEPLOY_DIR=/opt/keasy/keasy           # this repo's keasy/ on the manager

# Image pins (or source deploy/environments/prod/versions.env).
KEASY_SERVER_IMAGE=ghcr.io/kanzo-tech/keasy-server:0.4.0
KEASY_WEB_IMAGE=ghcr.io/kanzo-tech/keasy-web:0.4.0
KEASY_CONTROL_PLANE_IMAGE=ghcr.io/kanzo-tech/keasy-control-plane:0.4.0

# Base secret seeds (used once to `docker secret create`; rotate out-of-band after).
KC_DB_PASSWORD=change-me
KC_ADMIN_PASSWORD=change-me
CP_OIDC_SECRET=change-me                    # must match the keasy-control-plane realm client secret

# ── Optional: Litestream durability for tenant keasy.db ──────────────────────
# KEASY_LITESTREAM_REPLICA_BASE=s3://keasy-backups/litestream
# KEASY_LITESTREAM_CREDS=LITESTREAM_ACCESS_KEY_ID=...\nLITESTREAM_SECRET_ACCESS_KEY=...
