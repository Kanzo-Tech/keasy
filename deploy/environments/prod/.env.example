# Copy to `.env` (gitignored) on the Swarm manager and fill the required block.
# Read by infra/stack/bootstrap.sh (`make deploy-base`). The secrets below are
# OPTIONAL — if omitted, the bootstrap generates them, appends them here, and
# wires each to its consumers (Swarm secret + Keycloak realm) automatically.

# ── Required ────────────────────────────────────────────────────────────────
# No domain? Use sslip.io — it resolves <anything>.<IP>.sslip.io to <IP> with no
# DNS setup, and Let's Encrypt still issues per-host certs. Just swap in your IP:
#   KC_HOSTNAME=auth.203.0.113.10.sslip.io
#   KEASY_BASE_DOMAIN=203.0.113.10.sslip.io
KC_HOSTNAME=auth.keasy.example.com          # Keycloak's public host
KEASY_BASE_DOMAIN=keasy.example.com         # tenants at <slug>.<this>
ACME_EMAIL=ops@kanzo.tech                   # Let's Encrypt registration
KEASY_DEPLOY_DIR=/opt/keasy/keasy           # this repo's keasy/ on the manager

# Fleet image pins do NOT live here — they are git-tracked fleet-config in
# deploy/environments/prod/versions.env, sourced automatically by bootstrap.sh + cp.sh.
# This file is operator secrets + hostnames only.

# ── Secrets — leave unset to auto-generate (bootstrap appends them here) ──────
# KC_DB_PASSWORD=
# KC_ADMIN_PASSWORD=
# CP_OIDC_SECRET=          # minted once → cp-oidc-secret Swarm secret + the realm client

# ── Optional: Litestream durability for tenant keasy.db ──────────────────────
# KEASY_LITESTREAM_REPLICA_BASE=s3://keasy-backups/litestream
# KEASY_LITESTREAM_CREDS=LITESTREAM_ACCESS_KEY_ID=...\nLITESTREAM_SECRET_ACCESS_KEY=...
