# Fleet image pins — the single source for the fleet's default images.
#
# This is git-tracked fleet-config (the tenant registry lives in Keycloak, NOT here:
# it carries no per-tenant data, no PII — just "what version is the fleet on"). It is
# sourced by infra/stack/bootstrap.sh and infra/stack/cp.sh ALONGSIDE .env, which holds
# only operator secrets + hostnames and never image pins (one pin, one place).
#
# Renovate bumps these; the next `make reconcile` rolls every tenant that has no
# per-tenant `server_image` org-attribute pin (the canary override).
KEASY_SERVER_IMAGE=ghcr.io/kanzo-tech/keasy-server:0.0.3
KEASY_WEB_IMAGE=ghcr.io/kanzo-tech/keasy-web:0.0.3
KEASY_CONTROL_PLANE_IMAGE=ghcr.io/kanzo-tech/keasy-control-plane:0.0.3

# Third-party pins for the base stack + realm provisioning (also fleet-config).
# Keycloak stays at 26.2 (26.5.x regressed on org-enabled realms); terraform runs as a
# one-shot container (no install on the manager).
KEASY_KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.2
KEASY_TERRAFORM_IMAGE=hashicorp/terraform:1.9
