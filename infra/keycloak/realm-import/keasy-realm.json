{
  "realm": "keasy",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,
  "verifyEmail": false,
  "accessTokenLifespan": 3600,
  "ssoSessionMaxLifespan": 86400,
  "clientScopes": [
    {
      "name": "keasy-dataspaces",
      "description": "Maps keasy.dataspaces user attribute to keasy:dataspaces ID-token claim",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "keasy-dataspaces",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "keasy.dataspaces",
            "claim.name": "keasy:dataspaces",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "keasy-server",
      "name": "Keasy Server",
      "description": "Single-instance dev setup — OIDC relying party",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${KEASY_OIDC_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "http://localhost:8080/v1/auth/oidc-callback",
        "http://localhost:3000/v1/auth/oidc-callback"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8080/*##http://localhost:3000/*"
      },
      "defaultClientScopes": ["openid", "profile", "email", "keasy-dataspaces"]
    }
  ],
  "users": [
    {
      "id": "aaaa0000-0000-0000-0000-000000000001",
      "username": "promotor@keasy.dev",
      "email": "promotor@keasy.dev",
      "firstName": "Admin",
      "lastName": "Promotor",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "promotor", "temporary": false }]
    },
    {
      "id": "bbbb0000-0000-0000-0000-000000000001",
      "username": "participant@keasy.dev",
      "email": "participant@keasy.dev",
      "firstName": "User",
      "lastName": "Participant",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "participant", "temporary": false }]
    }
  ]
}
