{
  "realm": "keasy",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,
  "verifyEmail": false,
  "accessTokenLifespan": 3600,
  "ssoSessionMaxLifespan": 86400,
  "clients": [
    {
      "clientId": "keasy-server",
      "name": "Keasy Server",
      "description": "Keasy application server — OIDC relying party and admin API client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${KEASY_OIDC_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "http://localhost:8080/v1/auth/oidc-callback",
        "http://localhost:3000/v1/auth/oidc-callback"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8080/*##http://localhost:3000/*"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ]
    }
  ],
  "users": [
    {
      "id": "aaaaaaaa-0000-0000-0000-000000000001",
      "username": "admin@keasy.dev",
      "email": "admin@keasy.dev",
      "firstName": "Ada",
      "lastName": "Lovelace",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "admin", "temporary": false }
      ]
    },
    {
      "id": "aaaaaaaa-0000-0000-0000-000000000002",
      "username": "user@keasy.dev",
      "email": "user@keasy.dev",
      "firstName": "Alan",
      "lastName": "Turing",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "user", "temporary": false }
      ]
    }
  ]
}
