{
  "realm": "keasy",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,
  "verifyEmail": false,
  "accessTokenLifespan": 3600,
  "ssoSessionMaxLifespan": 86400,
  "clientScopes": [
    {
      "name": "profile",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "given name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "user.attribute": "firstName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "given_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "family name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "user.attribute": "lastName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "family_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "config": {
            "id.token.claim": "true",
            "introspection.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "user.attribute": "emailVerified",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email_verified",
            "jsonType.label": "boolean"
          }
        }
      ]
    },
    {
      "name": "keasy-workspaces",
      "description": "Maps keasy.workspaces user attribute to keasy:workspaces ID-token claim",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "keasy-workspaces",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "keasy.workspaces",
            "claim.name": "keasy:workspaces",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "keasy-server",
      "name": "Keasy Server",
      "description": "Single-instance dev setup — OIDC relying party",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${KEASY_OIDC_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "http://localhost:8080/v1/auth/oidc-callback",
        "http://localhost:3000/v1/auth/oidc-callback"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8080/*##http://localhost:3000/*"
      },
      "defaultClientScopes": ["openid", "profile", "email", "keasy-workspaces"]
    }
  ],
  "users": [
    {
      "id": "aaaa0000-0000-0000-0000-000000000001",
      "username": "owner@keasy.dev",
      "email": "owner@keasy.dev",
      "firstName": "Admin",
      "lastName": "Owner",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "owner", "temporary": false }]
    },
    {
      "id": "bbbb0000-0000-0000-0000-000000000001",
      "username": "member@keasy.dev",
      "email": "member@keasy.dev",
      "firstName": "User",
      "lastName": "Member",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "member", "temporary": false }]
    }
  ]
}
