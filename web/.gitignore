# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated — source of truth is /openapi.json at repo root
src/lib/api/openapi.json

# Phase 16 — vendored Fossil packages (npm pack tarballs, see ADR-0038 in fossil repo)
vendor/fossil-lang/*.tgz

# fossil-wasm artefact staged into public/ by scripts/copy-fossil-wasm.mjs (predev/prebuild)
public/fossil/
