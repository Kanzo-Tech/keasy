FROM node:22-alpine

WORKDIR /app
# The vendored @fossil-lang/* packages are `file:./vendor/...tgz` deps, so they
# must be present before `npm ci` (else ENOENT on the tarballs).
COPY package.json package-lock.json ./
COPY vendor ./vendor
RUN npm ci
COPY tsconfig.json next.config.ts postcss.config.mjs components.json eslint.config.mjs ./

EXPOSE 3000
CMD ["npm", "run", "dev"]
