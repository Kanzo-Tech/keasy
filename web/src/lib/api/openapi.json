  "components": {
    "schemas": {
      "AiSettingsPayload": {
        "type": "object",
        "required": [
          "provider",
          "api_key"
        ],
        "properties": {
          "api_key": {
            "type": "string"
          },
          "max_tokens": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
            "minimum": 0
          },
          "model": {
            "type": [
              "string",
              "null"
            ]
          },
          "provider": {
            "type": "string"
          }
        }
      },
      "CloudAccountSummary": {
        "type": "object",
        "required": [
          "id",
          "name",
          "provider_id",
          "fields"
        ],
        "properties": {
          "auth_method": {
            "type": [
              "string",
              "null"
            ]
          },
          "fields": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "provider_id": {
            "type": "string"
          }
        }
      },
      "Connection": {
        "type": "object",
        "required": [
          "id",
          "name",
          "kind",
          "location_type",
          "url"
        ],
        "properties": {
          "cloud_account_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "id": {
            "type": "string"
          },
          "kind": {
            "$ref": "#/components/schemas/ConnectionKind"
          },
          "location_type": {
            "$ref": "#/components/schemas/LocationType"
          },
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "ConnectionKind": {
        "type": "string",
        "enum": [
          "data",
          "vocab"
        ]
      },
      "CreateCloudAccountRequest": {
        "type": "object",
        "required": [
          "name",
          "provider_id",
          "fields"
        ],
        "properties": {
          "auth_method": {
            "type": [
              "string",
              "null"
            ]
          },
          "fields": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "name": {
            "type": "string"
          },
          "provider_id": {
            "type": "string"
          }
        }
      },
      "CreateConnectionRequest": {
        "type": "object",
        "required": [
          "name",
          "kind",
          "location_type",
          "url"
        ],
        "properties": {
          "cloud_account_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "kind": {
            "$ref": "#/components/schemas/ConnectionKind"
          },
          "location_type": {
            "$ref": "#/components/schemas/LocationType"
