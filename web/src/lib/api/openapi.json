    "/v1/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "POST /v1/auth/logout",
        "description": "Destroys the session cookie and removes the user_sessions DB entry.\nReturns 200 with `end_session_url` — the Keycloak end-session URL for full\nsingle logout. The frontend redirects the browser to this URL to complete\nthe OIDC RP-Initiated Logout flow.\n\nIf OIDC is not configured, `end_session_url` is null and the caller only\nneeds to clear the local session (existing VC behavior is preserved).",
        "operationId": "logout",
        "responses": {
          "200": {
            "description": "Logout successful, returns end_session_url"
          }
        }
      }
    },
    "/v1/auth/me": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "GET /v1/auth/me",
        "description": "Returns the authenticated user's profile, org, and effective role.\nProtected by session_required but NOT tenant_context_required.",
        "operationId": "get_me",
        "responses": {
          "200": {
            "description": "Authenticated user profile"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    },
    "/v1/auth/workspaces": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "GET /v1/auth/workspaces",
        "description": "Returns the list of dataspaces the authenticated user has access to,\nresolved from the `dataspaces` session value to display info via\nthe oidc_clients table. Protected by session_required, NOT tenant_context_required.",
        "operationId": "list_workspaces",
        "responses": {
          "200": {
            "description": "List of accessible workspaces"
          }
        }
      }
    },
